{
  "name": "@atm/db",
  "private": true,
  "version": "0.1.0",
  "scripts": {
    "build": "echo \"Database package build is handled by Prisma\"",
    "db:generate": "prisma generate",
    "db:migrate": "prisma migrate dev --schema prisma/schema.prisma",
    "db:seed": "node prisma/seed.js",
    "dev": "echo \"Use prisma migrate and seed commands during schema sessions\"",
    "lint": "prisma validate",
    "typecheck": "prisma validate"
  },
  "prisma": {
    "seed": "node prisma/seed.js"
  },
  "dependencies": {
    "@prisma/client": "^6.4.1"
  },
  "devDependencies": {
    "prisma": "^6.4.1"
  }
}
