{
  "name": "ai-talent-marketplace-platform",
  "private": true,
  "version": "0.1.0",
  "packageManager": "npm@10.9.2",
  "workspaces": [
    "apps/*",
    "packages/*",
    "services/ai-engine"
  ],
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev --parallel --filter=@atm/web --filter=@atm/api --filter=@atm/ai-engine",
    "dev:web": "turbo run dev --filter=@atm/web",
    "dev:api": "turbo run dev --filter=@atm/api",
    "dev:mobile": "turbo run dev --filter=@atm/mobile",
    "dev:ai": "turbo run dev --filter=@atm/ai-engine",
    "deploy:check": "node ./scripts/validate-deploy-env.mjs",
    "deploy:status": "node ./scripts/deploy-readiness.mjs",
    "deploy:remediate": "node ./scripts/deploy-remediation-report.mjs",
    "deploy:remediate:json": "node ./scripts/deploy-remediation-report.mjs --json",
    "deploy:prepare": "node ./scripts/prepare-deploy-env-files.mjs",
    "deploy:verify": "node ./scripts/verify-deploy.mjs",
    "deploy:verify:mobile": "node ./scripts/verify-mobile-hosted.mjs",
    "deploy:verify:all": "node ./scripts/check-deploy-env-files.mjs && npm run deploy:remediate && npm run deploy:verify -- .env.production.web .env.production.api .env.production.ai && npm run deploy:verify:mobile -- .env.production.mobile",
    "lint": "turbo run lint",
    "smoke:session18": "node ./scripts/session18-smoke.mjs",
    "typecheck": "turbo run typecheck",
    "db:generate": "turbo run db:generate --filter=@atm/db",
    "db:migrate": "npm run db:migrate --workspace @atm/db",
    "db:seed": "npm run db:seed --workspace @atm/db"
  },
  "devDependencies": {
    "turbo": "^2.5.0",
    "typescript": "^5.8.2"
  }
}
